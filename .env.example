# URL base de la API UniPH (sin /api al final)
# En desarrollo: usar cadena vacía para que el proxy (proxy.conf.json) reenvíe /api al backend
# En producción: URL absoluta del backend (ej. https://api.ejemplo.com)
API_URL=

# WebSockets (opcional, Fase 12). Si no se definen, se usa polling.
# Ejemplo Soketi: ws://localhost:6001
# WS_URL=
# PUSHER_KEY=app-key
